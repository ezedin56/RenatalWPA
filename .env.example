PORT=5000
NODE_ENV=development

# MongoDB (provide your connection string, or leave as local)
MONGODB_URI=mongodb://localhost:27017/house_rental

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production_2024
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your_refresh_secret_change_in_production_2024
JWT_REFRESH_EXPIRE=30d

# Admin default credentials (created by seeder)
ADMIN_EMAIL=admin@houserental.com
ADMIN_PASSWORD=admin123

# Email (optional - notifications will be skipped if not set)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=House Rental <noreply@houserental.com>

# CORS origins (comma separated)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000
