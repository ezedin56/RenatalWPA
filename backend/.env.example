PORT=5000
NODE_ENV=development

# MongoDB — local or Atlas. For Atlas, URL-encode special chars in the password
# (e.g. @ → %40). Example: mongodb+srv://user:pass%40word@cluster.xxx.mongodb.net/house_rental
MONGODB_URI=mongodb://localhost:27017/house_rental

# JWT — placeholder values below are INVALID when NODE_ENV=production (server will exit).
JWT_SECRET=your_super_secret_jwt_key_change_in_production_2024
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your_refresh_secret_change_in_production_2024
JWT_REFRESH_EXPIRE=30d

# Admin default credentials (created by seeder)
ADMIN_EMAIL=admin@houserental.com
ADMIN_PASSWORD=admin123

# Email (optional — forgot-password reset links when configured; registration OTP is logged to the API terminal only for now)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=House Rental <noreply@houserental.com>

# CORS — server.js uses FRONTEND_URL (single origin)
FRONTEND_URL=http://localhost:5173
